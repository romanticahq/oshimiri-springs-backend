generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Int?
  priceLabel  String?
  currency    String   @default("NGN")
  condition   String
  location    String
  coverageArea String?
  imageUrl    String?
  imageUrls   String[] @default([])
  sellerName  String?
  sellerWhatsapp String?
  sellerId    String?
  vehicleMakeModel String?
  yearRange   String?
  position    String?
  brand       String?
  batterySize String?
  inStock     Boolean  @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  seller     Seller?  @relation(fields: [sellerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seller {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  whatsapp    String
  accessCode  String?   @unique
  phone       String?
  location    String?
  coverageArea String?
  specialty   String?
  description String?
  verified    Boolean   @default(false)
  rating      String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Engineer {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  whatsapp    String
  phone       String?
  location    String
  coverageArea String?
  specialty   String
  experience  String?
  description String?
  verified    Boolean  @default(false)
  rating      String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductSubmission {
  id          String   @id @default(cuid())
  name        String
  categorySlug String
  price       Int?
  priceLabel  String?
  condition   String
  location    String
  coverageArea String?
  imageUrl    String?
  imageUrls   String[] @default([])
  sellerName  String
  sellerWhatsapp String
  sellerAccessCode String?
  vehicleMakeModel String?
  yearRange   String?
  position    String?
  brand       String?
  batterySize String?
  description String?
  status      String   @default("pending")
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
